YOUTUBE_COLLECTION=youtube
FACEBOOK_COLLECTION=facebook
XTWEETS_COLLECTION=xtweets
YOUTUBE_WITH_CHANNEL_COLLECTION=youtubeWithChannel

TWITTER_BASE_URL=https://api.twitter.com/2/
APIFY_ACTOR_ID=facebook-search-task
APIFY_USERNAME=your_apify_username

# Identity Configs
MODI_USERNAMES=LalitKModi,ruchirlmodi,DrBkModi1
