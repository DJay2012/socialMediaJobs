# Social Media Jobs Configuration — copy to .env and fill in real values

# Database Configuration
MONGO_URI=mongodb://USER:PASSWORD@HOST:PORT/
DB_NAME=smFeeds

# Secondary MongoDB
MONGO_URI_PRODUCTION=mongodb://USER:PASSWORD@HOST:PORT/DB?authSource=admin&replicaSet=rs0&tls=true

# Collection Names
